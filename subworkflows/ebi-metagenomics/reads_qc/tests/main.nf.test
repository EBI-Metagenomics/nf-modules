nextflow_workflow {

    name "Test Subworkflow READS_QC"
    script "../main.nf"
    workflow "READS_QC"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_nfcore"
    tag "subworkflows/reads_qc"
    tag "seqfu/check"
    tag "fastqsuffixheadercheck"
    tag "pimento/generatebcv"
    tag "librarystrategycheck"
    tag "subworkflows/../../modules/nf-core/fastp"
    tag "subworkflows/../../modules/nf-core/seqtk"
    tag "subworkflows/../../modules/nf-core/seqtk/seq"

    setup {
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [
                [name: "fastp",     sha: "d9ec4ef289ad39b8a662a7a12be50409b11df84b"],
                [name: "seqtk/seq", sha: "41dfa3f7c0ffabb96a6a813fe321c6d1cc5b6e46"]
            ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("test_reads_qc_success") {

        when {
            params {
                save_trimmed_fail = true
            }
            workflow {
                """
                input[0] = true
                input[1] = Channel.fromList([
                        [
                            [ id:'SRR21814853', single_end:false ], // meta map
                            [ file("${moduleDir}/tests/fixtures/SRR21814853_1.fastq.gz", checkIfExists: true),
                            file("${moduleDir}/tests/fixtures/SRR21814853_2.fastq.gz", checkIfExists: true)
                            ]
                        ]
                    ])
                input[2] = ""
                input[3] = true
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.seqfu_check,
                    workflow.out.suffix_header_check,
                    workflow.out.amplicon_check,
                    workflow.out.reads,
                    workflow.out.reads_se_and_merged,
                    workflow.out.reads_fasta,
                    workflow.out.versions.collect { path(it).yaml }
                    ).match()
                },
                {
                    def fastp = workflow.out.fastp_summary_json.collectEntries { item ->
                        [item[0].id, new groovy.json.JsonSlurper().parseText(path(item[1]).text)]
                    }
                    assert fastp["SRR21814853"].summary.before_filtering.total_reads == 71282
                    assert fastp["SRR21814853"].summary.before_filtering.total_bases == 21353646
                    assert fastp["SRR21814853"].summary.after_filtering.total_reads  == 4602
                    assert fastp["SRR21814853"].summary.after_filtering.total_bases  == 1837390
                }
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    test("test_reads_qc_success_PE_and_SE") {

        when {
            params {
                save_trimmed_fail = true
            }
            workflow {
                """
                input[0] = true
                input[1] = Channel.fromList([
                        [
                            [ id:'SRR21814853', single_end:false ], // meta map
                            [ file("${moduleDir}/tests/fixtures/SRR21814853_1.fastq.gz", checkIfExists: true),
                            file("${moduleDir}/tests/fixtures/SRR21814853_2.fastq.gz", checkIfExists: true)
                            ]
                        ],
                        [
                            [ id:'SRR9674626', single_end:true ], // meta map
                            file("${moduleDir}/tests/fixtures/SRR9674626.fastq.gz", checkIfExists: true),
                        ]
                    ])
                input[2] = ""
                input[3] = true
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.seqfu_check,
                    workflow.out.suffix_header_check,
                    workflow.out.amplicon_check,
                    workflow.out.reads,
                    workflow.out.reads_se_and_merged,
                    workflow.out.reads_fasta,
                    workflow.out.versions.collect { path(it).yaml }
                    ).match()
                },
                {
                    def fastp = workflow.out.fastp_summary_json.collectEntries { item ->
                        [item[0].id, new groovy.json.JsonSlurper().parseText(path(item[1]).text)]
                    }
                    assert fastp["SRR21814853"].summary.before_filtering.total_reads == 71282
                    assert fastp["SRR21814853"].summary.before_filtering.total_bases == 21353646
                    assert fastp["SRR21814853"].summary.after_filtering.total_reads  == 4602
                    assert fastp["SRR21814853"].summary.after_filtering.total_bases  == 1837390
                    assert fastp["SRR9674626"].summary.before_filtering.total_reads  == 64176
                    assert fastp["SRR9674626"].summary.before_filtering.total_bases  == 10309910
                    assert fastp["SRR9674626"].summary.after_filtering.total_reads   == 64176
                    assert fastp["SRR9674626"].summary.after_filtering.total_bases   == 10309910
                }
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    test("test_reads_fail_seqfu") {

        when {
            params {
                save_trimmed_fail = true
            }
            workflow {
                """
                input[0] = true
                input[1] = Channel.fromList([
                    [
                        [ id:'SRR21814853', single_end:false ], // meta map
                        [ file("${moduleDir}/tests/fixtures/SRR21814853_1.fastq.gz", checkIfExists: true),
                        file("${moduleDir}/tests/fixtures/SRR21814853_2.fastq.gz", checkIfExists: true)
                        ]
                    ],
                    [
                        [ id:'ERR4674038', single_end:false ], // meta map
                        [ file("${moduleDir}/tests/fixtures/ERR4674038_test_readcount_1.fastq", checkIfExists: true),
                        file("${moduleDir}/tests/fixtures/ERR4674038_test_readcount_2.fastq", checkIfExists: true)
                        ]
                    ]
                ])
                input[2] = ""
                input[3] = true
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.seqfu_check,
                    workflow.out.suffix_header_check,
                    workflow.out.amplicon_check,
                    workflow.out.reads,
                    workflow.out.reads_se_and_merged,
                    workflow.out.reads_fasta,
                    workflow.out.versions.collect { path(it).yaml }
                    ).match()
                },
                {
                    def fastp = workflow.out.fastp_summary_json.collectEntries { item ->
                        [item[0].id, new groovy.json.JsonSlurper().parseText(path(item[1]).text)]
                    }
                    // ERR4674038 fails seqfu check and is excluded from fastp
                    assert !fastp.containsKey("ERR4674038")
                    assert fastp["SRR21814853"].summary.before_filtering.total_reads == 71282
                    assert fastp["SRR21814853"].summary.before_filtering.total_bases == 21353646
                    assert fastp["SRR21814853"].summary.after_filtering.total_reads  == 4602
                    assert fastp["SRR21814853"].summary.after_filtering.total_bases  == 1837390
                }
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    test("test_reads_fail_suffixheader") {

        when {
            params {
                save_trimmed_fail = true
            }
            workflow {
                """
                input[0] = true
                input[1] = Channel.fromList([
                    [
                        [ id:'SRR21814853', single_end:false ], // meta map
                        [ file("${moduleDir}/tests/fixtures/SRR21814853_1.fastq.gz", checkIfExists: true),
                        file("${moduleDir}/tests/fixtures/SRR21814853_2.fastq.gz", checkIfExists: true)
                        ]
                    ],
                    [
                        [ id:'ERR4674038', single_end:false ], // meta map
                        [ file("${moduleDir}/tests/fixtures/ERR4674038witherror_1.fastq.gz", checkIfExists: true),
                        file("${moduleDir}/tests/fixtures/ERR4674038witherror_2.fastq.gz", checkIfExists: true)
                        ]
                    ]
                ])
                input[2] = ""
                input[3] = true
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.seqfu_check,
                    workflow.out.suffix_header_check,
                    workflow.out.amplicon_check,
                    workflow.out.reads,
                    workflow.out.reads_se_and_merged,
                    workflow.out.reads_fasta,
                    workflow.out.versions.collect { path(it).yaml }
                    ).match()
                },
                {
                    def fastp = workflow.out.fastp_summary_json.collectEntries { item ->
                        [item[0].id, new groovy.json.JsonSlurper().parseText(path(item[1]).text)]
                    }
                    // ERR4674038 fails suffix/header check and is excluded from fastp
                    assert !fastp.containsKey("ERR4674038")
                    assert fastp["SRR21814853"].summary.before_filtering.total_reads == 71282
                    assert fastp["SRR21814853"].summary.before_filtering.total_bases == 21353646
                    assert fastp["SRR21814853"].summary.after_filtering.total_reads  == 4602
                    assert fastp["SRR21814853"].summary.after_filtering.total_bases  == 1837390
                }
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    test("test_reads_onlyfail") {

        when {
            params {
                save_trimmed_fail = true
            }
            workflow {
                """
                input[0] = true
                input[1] = Channel.fromList([
                    [
                        [ id:'ERR4674038', single_end:false ], // meta map
                        [ file("${moduleDir}/tests/fixtures/ERR4674038witherror_1.fastq.gz", checkIfExists: true),
                        file("${moduleDir}/tests/fixtures/ERR4674038witherror_2.fastq.gz", checkIfExists: true)
                        ]
                    ]
                ])
                input[2] = ""
                input[3] = true
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.seqfu_check,
                    workflow.out.suffix_header_check,
                    workflow.out.amplicon_check,
                    workflow.out.reads,
                    workflow.out.reads_se_and_merged,
                    workflow.out.reads_fasta,
                    workflow.out.versions.collect { path(it).yaml }
                    ).match()
                },
                { assert workflow.out.fastp_summary_json.size() == 0 }
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    test("test_reads_qc_notamplicon") {

        when {
            params {
                save_trimmed_fail = true
            }
            workflow {
                """
                input[0] = false
                input[1] = Channel.fromList([
                        [
                            [ id:'SRR21814853', single_end:false ], // meta map
                            [ file("${moduleDir}/tests/fixtures/SRR21814853_1.fastq.gz", checkIfExists: true),
                            file("${moduleDir}/tests/fixtures/SRR21814853_2.fastq.gz", checkIfExists: true)
                            ]
                        ]
                    ])
                input[2] = ""
                input[3] = true
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.seqfu_check,
