                    workflow.out.reads,
                    workflow.out.reads_se_and_merged,
                    workflow.out.reads_fasta,
                    workflow.out.versions.collect { path(it).yaml }
                    ).match()
                },
                {
                    def fastp = workflow.out.fastp_summary_json.collectEntries { item ->
                        [item[0].id, new groovy.json.JsonSlurper().parseText(path(item[1]).text)]
                    }
                    assert fastp["SRR21814853"].summary.before_filtering.total_reads == 71282
                    assert fastp["SRR21814853"].summary.before_filtering.total_bases == 21353646
                    assert fastp["SRR21814853"].summary.after_filtering.total_reads  == 4602
